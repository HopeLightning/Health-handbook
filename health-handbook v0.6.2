<script>
// Tab 配置
var TABS={
  daily:['overview','sleep','bowel','mood','vitals'],
  monthly:['overview','cardio','flex','weight','muscle'],
  yearly:['yearly','faq']
};
var SEC_ID={
  'daily-overview':'sec-daily-overview','daily-sleep':'sec-daily-sleep',
  'daily-bowel':'sec-daily-bowel','daily-mood':'sec-daily-mood',
  'daily-vitals':'sec-daily-vitals',
  'monthly-overview':'sec-monthly-overview','monthly-cardio':'sec-monthly-cardio',
  'monthly-flex':'sec-monthly-flex','monthly-weight':'sec-monthly-weight',
  'monthly-muscle':'sec-monthly-muscle',
  'yearly-yearly':'sec-yearly','yearly-faq':'sec-faq'
};
var ICONS={overview:'📋',sleep:'😴',bowel:'🚽',mood:'😊',vitals:'🩺',
  cardio:'❤️',flex:'🧘',weight:'⚖️',muscle:'💪',yearly:'🩺',faq:'❓'};
var NAMES={overview:'总览',sleep:'睡眠',bowel:'排泄',mood:'情绪',vitals:'体征',
  cardio:'心肺',flex:'柔韧',weight:'体重',muscle:'肌肉',yearly:'年度提醒',faq:'常见问题'};
var currentTier='daily',currentTab='overview';
var state={};

// 每个测试项必填字段定义
var REQUIRED_FIELDS={
  sleep:['sleep-time','sleep-energy','sleep-drowse'],
  mood:['mood-score','stress','social'],
  cardio:['walk-test','hr-recovery'],
  flex:['sit-reach','shoulder','hip'],
  muscle:['grip','pushup','plank']
};

function setTier(t){
  currentTier=t;
  document.querySelectorAll('.tier-btn').forEach(function(b){b.classList.remove('active')});
  document.getElementById('tier-'+t+'-btn').classList.add('active');
  var bar=document.getElementById('tabBar');
  var firstTab=TABS[t][0];
  var html='';
  TABS[t].forEach(function(tab){
    var active=(tab===firstTab)?'active':'';
    html+='<button class="tab-btn '+active+'" id="tab-'+tab+'" onclick="setTab(\''+tab+'\')">'+ICONS[tab]+' '+NAMES[tab]+'</button>';
  });
  bar.innerHTML=html;
  bar.style.display='flex';
  setTab(firstTab);
}

function setTab(tab){
  currentTab=tab;
  document.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active')});
  var btn=document.getElementById('tab-'+tab);
  if(btn)btn.classList.add('active');
  showSection(tab);
}

function showSection(tab){
  document.querySelectorAll('.section').forEach(function(s){s.classList.remove('active')});
  var key=currentTier+'-'+tab;
  var secId=SEC_ID[key];
  var sec=secId?document.getElementById(secId):null;
  if(sec)sec.classList.add('active');
}

function toggleTest(id){
  var header=document.querySelector('#test-'+id+' .test-header');
  var body=document.getElementById('body-'+id);
  header.classList.toggle('open');
  body.classList.toggle('open');
}

// 通用评分选择
function selectScore(key,el,val,testId){
  var par=el.parentElement;
  if(par.classList.contains('sg')){
    var items=par.querySelectorAll('.so');
    for(var j=0;j<items.length;j++)items[j].classList.remove('sel','warn');
  }
  el.classList.add('sel');
  if(!state[currentTier])state[currentTier]={};
  if(!state[currentTier][testId])state[currentTier][testId]={};
  state[currentTier][testId][key]=val;
  
  // 自动判定
  autoEvaluate(testId);
}

// 自动判定函数
function autoEvaluate(testId){
  if(!state[currentTier]||!state[currentTier][testId])return;
  
  var s=state[currentTier][testId];
  var card=document.getElementById('test-'+testId);
  var status=document.getElementById('status-'+testId);
  var result=document.getElementById('result-'+testId);
  var fail=false;
  var failReasons=[];
  
  if(testId==='sleep'){
    // 睡眠判定规则
    if(s['sleep-drowse']===2){fail=true;failReasons.push('白天嗜睡明显');}
    if(s['sleep-time']===1){fail=true;failReasons.push('入睡时长>30分钟');}
    if(s['sleep-energy']&&s['sleep-energy']<=2){fail=true;failReasons.push('晨起精力差');}
    showResult(result,fail,failReasons,'sleep');
  }
  else if(testId==='mood'){
    // 情绪判定规则
    if(s['mood-score']&&s['mood-score']<=3){fail=true;failReasons.push('情绪评分偏低');}
    if(s['stress']>=2){fail=true;failReasons.push('压力程度较大');}
    if(s['social']===0){fail=true;failReasons.push('社交不足');}
    showResult(result,fail,failReasons,'mood');
  }
  else if(testId==='cardio'){
    // 心肺判定规则
    if(s['walk-test']===1){fail=true;failReasons.push('步行距离<300m');}
    if(s['hr-recovery']===1){fail=true;failReasons.push('心率恢复慢');}
    showResult(result,fail,failReasons,'cardio');
  }
  else if(testId==='flex'){
    // 柔韧性判定规则
    if(s['sit-reach']===1){fail=true;failReasons.push('体前屈受限');}
    if(s['shoulder']===1){fail=true;failReasons.push('肩部柔韧差');}
    if(s['hip']===1){fail=true;failReasons.push('髋关节活动受限');}
    showResult(result,fail,failReasons,'flex');
  }
  else if(testId==='muscle'){
    // 肌肉判定规则
    if(s['grip']===1){fail=true;failReasons.push('握力下降');}
    if(s['pushup']===1){fail=true;failReasons.push('俯卧撑<5个');}
    if(s['plank']===1){fail=true;failReasons.push('平板支撑<30秒');}
    showResult(result,fail,failReasons,'muscle');
  }
  
  // 更新卡片状态
  if(fail){
    card.classList.remove('done');
    card.classList.add('fail');
    status.className='test-status fail';
    status.textContent='需关注';
  }else{
    card.classList.remove('fail');
    card.classList.add('done');
    status.className='test-status pass';
    status.textContent='已完成';
  }
  updateProgress();
}

// 显示自动判定结果
function showResult(el,fail,reasons,testId){
  if(!el)return;
  el.classList.add('show');
  el.classList.remove('pass','fail');
  el.classList.add(fail?'fail':'pass');
  
  var icon=el.querySelector('.ar-icon');
  var text=el.querySelector('.ar-text');
  var badge=el.querySelector('.ar-badge');
  
  if(fail){
    icon.textContent='⚠️';
    text.textContent='检测到问题：'+reasons.join('、');
    badge.textContent='需关注';
  }else{
    icon.textContent='✅';
    var messages={
      sleep:'睡眠质量良好，继续保持规律作息',
      mood:'情绪状态正常，保持积极心态',
      cardio:'心肺功能良好，持续有氧运动',
      flex:'柔韧性良好，继续保持拉伸习惯',
      muscle:'肌肉力量良好，继续保持训练',
      bowel:'排泄功能正常',
      vitals:'体征指标正常'
    };
    text.textContent=messages[testId]||'各项指标正常';
    badge.textContent='正常';
  }
}

// 布里斯托大便分类
function selectBristol(v,el){
  var items=document.querySelectorAll('.bi');
  for(var i=0;i<items.length;i++)items[i].classList.remove('sel','warn');
  el.classList.add('sel');
  if(v>=5)el.classList.add('warn');
  
  if(!state[currentTier])state[currentTier]={};
  if(!state[currentTier].bowel)state[currentTier].bowel={};
  state[currentTier].bowel.bristol=v;
  
  var fail=v===1||v===2||v===7;
  var reasons=[];
  if(v===1||v===2)reasons.push('大便形态偏干，可能便秘');
  if(v===7)reasons.push('大便稀水状，可能腹泻');
  
  var card=document.getElementById('test-bowel');
  var status=document.getElementById('status-bowel');
  var result=document.getElementById('result-bowel');
  
  showResult(result,fail,reasons,'bowel');
  
  if(fail){
    card.classList.remove('done');
    card.classList.add('fail');
    status.className='test-status fail';
    status.textContent='需关注';
  }else{
    card.classList.remove('fail');
    card.classList.add('done');
    status.className='test-status pass';
    status.textContent='已完成';
  }
  updateProgress();
}

// 大便颜色选择
function selectBowelColor(c,el){
  var btns=el.parentElement.querySelectorAll('.cbtn');
  for(var i=0;i<btns.length;i++)btns[i].classList.remove('pass','warn','sel');
  el.classList.add('sel');
  
  if(!state[currentTier])state[currentTier]={};
  if(!state[currentTier].bowel)state[currentTier].bowel={};
  state[currentTier].bowel.color=c;
  
  if(c==='black'||c==='red'||c==='pale'){
    el.classList.add('warn');
    document.getElementById('bowel-color-msg').innerHTML='⚠️ <strong>建议就医检查</strong>，排除消化道出血等风险';
  }else if(c==='yellow'){
    document.getElementById('bowel-color-msg').innerHTML='黄色大便可能与饮食有关，持续出现请留意';
  }else{
    document.getElementById('bowel-color-msg').innerHTML='✅ 正常颜色，继续保持';
  }
}

// 小便颜色选择
function selectUrine(v,el){
  var btns=el.parentElement.querySelectorAll('.cbtn');
  for(var i=0;i<btns.length;i++)btns[i].classList.remove('pass','warn','sel');
  el.classList.add('sel');
  if(v==='dark'||v==='red')el.classList.add('warn');
  
  if(!state[currentTier])state[currentTier]={};
  if(!state[currentTier].bowel)state[currentTier].bowel={};
  state[currentTier].bowel.urine=v;
}

// 体征数据分析
function evalVitals(){
  var sys=parseFloat(document.getElementById('bp-sys').value)||0;
  var dia=parseFloat(document.getElementById('bp-dia').value)||0;
  var hr=parseFloat(document.getElementById('hr').value)||0;
  var temp=parseFloat(document.getElementById('temp').value)||0;
  var spo2=parseFloat(document.getElementById('spo2').value)||0;
  
  var fail=false;
  var reasons=[];
  
  if(sys>0||dia>0){
    if(sys>=140||dia>=90){fail=true;reasons.push('血压偏高('+sys+'/'+dia+'mmHg)');}
    else if(sys<90||dia<60){fail=true;reasons.push('血压偏低('+sys+'/'+dia+'mmHg)');}
  }
  if(hr>0){
    if(hr>100){fail=true;reasons.push('心率过快('+hr+'bpm)');}
    else if(hr<60){fail=true;reasons.push('心率过慢('+hr+'bpm)');}
  }
  if(temp>0){
    if(temp>37.5){fail=true;reasons.push('体温偏高('+temp+'℃)');}
    else if(temp<36.0){fail=true;reasons.push('体温偏低('+temp+'℃)');}
  }
  if(spo2>0&&spo2<95){
    fail=true;reasons.push('血氧偏低('+spo2+'%)');
  }
  
  var card=document.getElementById('test-vitals');
  var status=document.getElementById('status-vitals');
  var result=document.getElementById('result-vitals');
  
  showResult(result,fail,reasons,'vitals');
  
  if(fail){
    card.classList.remove('done');
    card.classList.add('fail');
    status.className='test-status fail';
    status.textContent='需关注';
  }else{
    card.classList.remove('fail');
    card.classList.add('done');
    status.className='test-status pass';
    status.textContent='已完成';
  }
  updateProgress();
}

// BMI计算
function calcBMI(){
  var w=parseFloat(document.getElementById('weight').value);
  var h=parseFloat(document.getElementById('height').value)/100;
  if(!w||!h||h<=0){alert('请输入有效的体重和身高');return;}
  
  var bmi=w/(h*h);
  document.getElementById('bmi-num').textContent=bmi.toFixed(1);
  var label='';
  if(bmi<18.5){label='偏瘦';document.getElementById('bmi-num').style.color='var(--warn)';}
  else if(bmi<24){label='正常';document.getElementById('bmi-num').style.color='var(--primary)';}
  else if(bmi<28){label='超重';document.getElementById('bmi-num').style.color='var(--accent)';}
  else{label='肥胖';document.getElementById('bmi-num').style.color='var(--warn)';}
  document.getElementById('bmi-label').textContent=label;
  document.getElementById('bmi-range').textContent='BMI '+bmi.toFixed(1)+' | 身高'+document.getElementById('height').value+'cm | 体重'+w+'kg';
  document.getElementById('bmi-result').style.display='block';
  
  // 自动判定体重
  var fail=bmi<18.5||bmi>=24;
  var reasons=[];
  if(bmi<18.5)reasons.push('BMI偏低，可能营养不良');
  if(bmi>=24&&bmi<28)reasons.push('BMI超重，建议控制饮食');
  if(bmi>=28)reasons.push('BMI肥胖，建议就医咨询');
  
  var waist=parseFloat(document.getElementById('waist').value)||0;
  if(waist>=90){fail=true;reasons.push('腰围超标，注意腹部肥胖');}
  
  var card=document.getElementById('test-weight');
  var status=document.getElementById('status-weight');
  var result=document.getElementById('result-weight');
  
  showResult(result,fail,reasons,'weight');
  
  if(fail){
    card.classList.remove('done');
    card.classList.add('fail');
    status.className='test-status fail';
    status.textContent='需关注';
  }else{
    card.classList.remove('fail');
    card.classList.add('done');
    status.className='test-status pass';
    status.textContent='已完成';
  }
  updateProgress();
}

function saveGoals(){
  var g={glucose:document.getElementById('goal-glucose').value,chol:document.getElementById('goal-chol').value,weight:document.getElementById('goal-weight').value,exercise:document.getElementById('goal-exercise').value};
  localStorage.setItem('health-goals',JSON.stringify(g));
  document.getElementById('goal-msg').textContent='✅ 年度目标已保存';
  setTimeout(function(){document.getElementById('goal-msg').textContent='';},3000);
}

function setExamReminder(){
  var d=document.getElementById('exam-date').value;
  if(!d){document.getElementById('exam-msg').textContent='请选择体检日期';return;}
  localStorage.setItem('exam-date',d);
  document.getElementById('exam-msg').textContent='✅ 已设置 '+d+' 的体检提醒';
  setTimeout(function(){document.getElementById('exam-msg').textContent='';},3000);
}

function toggleFaq(btn){
  var a=btn.nextElementSibling;
  a.classList.toggle('open');
  btn.classList.toggle('open');
}

function updateProgress(){
  if(currentTier==='yearly')return;
  var testIds=TABS[currentTier].filter(function(t){return t!=='overview'&&t!=='yearly'&&t!=='faq';});
  var done=0;
  testIds.forEach(function(id){
    var card=document.getElementById('test-'+id);
    if(card&&(card.classList.contains('done')||card.classList.contains('fail')))done++;
  });
  var total=testIds.length;
  var pct=(done/total*100).toFixed(0);
  var pt=document.getElementById(currentTier==='daily'?'d-p-text':'m-p-text');
  var pf=document.getElementById(currentTier==='daily'?'d-p-fill':'m-p-fill');
  var tip=document.getElementById(currentTier==='daily'?'d-p-tip':'m-p-tip');
  if(pt)pt.textContent=done+' / '+total;
  if(pf)pf.style.width=pct+'%';
  if(tip){
    if(done===0)tip.textContent='开始今天的记录吧 👇';
    else if(done<total)tip.textContent='继续加油，已完成'+done+'项 👏';
    else tip.textContent='🎉 今日全部完成！';
  }
  var roadmap=document.getElementById(currentTier==='daily'?'d-roadmap':'m-roadmap');
  if(roadmap&&done>0){roadmap.style.display='block';genAdvice();}
}

function genAdvice(){
  var el=document.getElementById(currentTier==='daily'?'d-advice':'m-advice');
  if(!el)return;
  var html='';
  if(currentTier==='daily'){
    var items=[];
    if(state.daily&&state.daily.sleep){
      if(state.daily.sleep['sleep-drowse']===2)items.push({ic:'😴',it:'白天嗜睡明显，建议调整作息或做睡眠呼吸监测',tag:'fail'});
      else if(state.daily.sleep['sleep-energy']>=4)items.push({ic:'✅',it:'睡眠质量不错，继续保持',tag:'pass'});
    }
    if(state.daily&&state.daily.bowel){
      if(state.daily.bowel.bristol===1||state.daily.bowel.bristol===2)items.push({ic:'🚽',it:'大便形态偏干便秘，增加膳食纤维和饮水',tag:'fail'});
      if(state.daily.bowel.bristol===6||state.daily.bowel.bristol===7)items.push({ic:'🚽',it:'大便偏稀，注意饮食清淡，必要时就医',tag:'fail'});
    }
    if(state.daily&&state.daily.mood){
      if(state.daily.mood['mood-score']&&state.daily.mood['mood-score']<=3)items.push({ic:'😊',it:'情绪偏低，注意自我调节，可尝试深呼吸或找人倾诉',tag:'fail'});
      if(state.daily.mood['social']===0)items.push({ic:'🤝',it:'今天社交偏少，建议主动联系亲友',tag:'fail'});
    }
    if(items.length===0)items.push({ic:'🎉',it:'今日各项指标良好，保持健康生活方式！',tag:'pass'});
    items.forEach(function(item){html+='<div class="ai"><span class="ic">'+item.ic+'</span><span class="it">'+item.it+'<span class="itag '+item.tag+'">'+(item.tag==='pass'?'正常':'建议关注')+'</span></span></div>';});
  }else{
    var mItems=[];
    if(state.monthly&&state.monthly.cardio){
      if(state.monthly.cardio['walk-test']===1)mItems.push({ic:'❤️',it:'心肺功能较弱，建议逐步增加有氧运动',tag:'fail'});
      else mItems.push({ic:'✅',it:'心肺功能正常',tag:'pass'});
    }
    if(state.monthly&&state.monthly.flex){
      if(state.monthly.flex['sit-reach']===1)mItems.push({ic:'🧘',it:'柔韧性偏弱，每天拉伸10分钟可改善',tag:'fail'});
      else mItems.push({ic:'✅',it:'柔韧性良好',tag:'pass'});
    }
    if(state.monthly&&state.monthly.muscle){
      if(state.monthly.muscle['pushup']===1)mItems.push({ic:'💪',it:'肌肉力量较弱，建议开始力量训练',tag:'fail'});
      else mItems.push({ic:'✅',it:'肌肉力量良好',tag:'pass'});
    }
    if(mItems.length===0)mItems.push({ic:'🎉',it:'本月各项检查均正常，继续保持！',tag:'pass'});
    mItems.forEach(function(item){html+='<div class="ai"><span class="ic">'+item.ic+'</span><span class="it">'+item.it+'<span class="itag '+item.tag+'">'+(item.tag==='pass'?'正常':'建议关注')+'</span></span></div>';});
  }
  el.innerHTML=html;
}

window.addEventListener('scroll',function(){
  var btn=document.getElementById('scrollTop');
  btn.classList.toggle('show',window.scrollY>300);
});

setTier('daily');
</script>
